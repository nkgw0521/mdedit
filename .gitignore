# Rust / Cargo のビルド成果物
# (Cargo.lock はアプリなので、あえて除外せずコミットする想定)
/src-tauri/target/
**/*.rs.bk

# Tauri がモバイル向けビルド等で生成するフォルダ(今は未使用だが念のため)
/src-tauri/gen/
/src-tauri/.cargo/

# 依存パッケージ取得などで一時的にnpmを使った場合の生成物
# (このプロジェクト自体はNode.js不要だが、vendor/以下のライブラリを
#  更新する際にnpmを使うことがあるため念のため除外)
node_modules/
package.json
package-lock.json
npm-debug.log*

# OSが自動生成するファイル
.DS_Store
Thumbs.db
Desktop.ini

# エディタ/IDE
.vscode/
.idea/
*.swp

# ログ
*.log
